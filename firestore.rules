rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /workRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }
    
    match /workers/{workerId} {
      // Temporarily open for read/write if auth is not strictly required yet,
      // but according to previous requirements, any logged-in user might read or owner.
      // Assuming previous rule if any was default.
      allow read, write: if request.auth != null;
    }

    match /inventory/{itemId} {
      allow read, write, delete: if request.auth != null;
    }
  }
}
